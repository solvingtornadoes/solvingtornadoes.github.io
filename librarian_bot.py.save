mport os

def run_librarian():
    drafts_dir = "website_drafts"
    index_file = "library_index.md"
    
    if not os.path.exists(drafts_dir):
        print(f"Error: {drafts_dir} folder not found.")
        return

    print("\n=== BOT B: THE LIBRARIAN (Organizing Knowledge Base) ===")
    
    # Scan for all markdown files
    files = [f for f in os.listdir(drafts_dir) if f.endswith('.md')]
    
    if not files:
        print("No expertise nodes found in drafts. Run Bot A first!")
        return

    library_items = []

    for filename in files:
        with open(os.path.join(drafts_dir, filename), 'r') as f:
            lines = f.readlines()
            # Simple logic to find the topic in the frontmatter
            topic = "Unknown Topic"
            for line in lines:
                if line.startswith("topic:"):
                    topic = line.split(":")[1].strip()
                    break
            library_items.append({"topic": topic, "file": filename})

    # Create the Master Index for AI Agents
    with open(index_file, "w") as idx:
        idx.write("# Tornado Project: Expert Knowledge Index\n")
        idx.write("This index is optimized for AI Agent traversal. Each link represents a core expertise node.\n\n")
        for item in library_items:
            idx.write(f"* [{item['topic']}]({drafts_dir}/{item['file']})\n")

    print(f"[SUCCESS]: Indexed {len(library_items)} nodes.")
    print(f"[STATUS]: '{index_file}' has been updated for AI crawlers.")

if __name__ == "__main__":
    run_librarian()
